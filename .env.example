# Required: your OpenAI API key (used for both embeddings and chat completions)
OPENAI_API_KEY=sk-...

# Optional overrides (sensible defaults are used if omitted)
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini

# Crawl limits -- keep these small for a take-home / demo
CRAWL_MAX_PAGES=25
CRAWL_MAX_DEPTH=2

# Retrieval tuning
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SCORE=0.25
